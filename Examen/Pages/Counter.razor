@page "/counter"
@using System.Text.RegularExpressions;
@using System.ComponentModel.DataAnnotations;
@using System.Text;

<PageTitle>ContainsChars28.11.2023</PageTitle>

<h1>Задание выглядит следующим образом:</h1>

<p role="status">
    1. Пользователь вводит в программу две строки <br>
    2. Программа должна найти наибольшее количество идущих подряд одинаковых символов. Например, пользователь вводит слова: «приключение» и «ключи». Повторяющиеся символы КЛЮЧ.
</p>
<EditForm Model="@model" >
 <MudPaper Class="pa-4">
     <MudForm>
            <MudTextField Label="Input..." For="@(() => model.str1)" Variant=Variant.Filled @bind-Value="model.str1"></MudTextField>
            <MudTextField Label="Input..." For="@(() => model.str2)" Variant=Variant.Filled @bind-Value="model.str2"></MudTextField>
        <div class="d-flex align-center justify-space-between">
                <MudButton Variant="Variant.Filled" Style="background-color:DeepSkyBlue;color:white; font-weight:bold; " OnClick="ChangeString" Class="ml-auto mr-auto mt-5">Вывести ответ</MudButton>
        </div>
     </MudForm>
     <h3>Результат: @result</h3>
 </MudPaper>
</EditForm>

<MudExpansionPanels>
    <MudExpansionPanel >
        <TitleContent>
            <h4> <strong> Вы можете посмотреть код здесь...</strong></h4>
        </TitleContent>
         <ChildContent>
            @_bigAsyncContent
         </ChildContent>
    </MudExpansionPanel>
</MudExpansionPanels>





