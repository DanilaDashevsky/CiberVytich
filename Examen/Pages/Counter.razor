    private void ChangeString()
    {
        if (model.str1 != "" && model.str2 != "")
        {
            if (model.str1.Length > model.str2.Length)
            {
                if (model.str1.Contains(model.str2))
                    result = model.str1;
                else
                    MyFunction(model.str1, model.str2);
            }
            else
            {
                if (model.str2.Contains(model.str1))
                    result = model.str1;

                else
                    MyFunction(model.str2, model.str1);
            }
        }
    }
    private static void MyFunction(string str1, string str2)
    {
        str2 += " ";
        List<string> arrResulst = new List<string>();
        arrResulst.Add("");
        int index = 1;
        int indexArr = 0;
        string clone1 = "";
        StringBuilder clone = new StringBuilder(str1); //создаю, потому что не имею прямого доступа перезаписи символ
        for (int i = 0; i < str2.Length - 1; i++)
        {
            clone1 = "" + str2[i]; //преобразую char в строку
            if (str1.IndexOf(clone1) != -1) //Проверяю, есть ли данный символ на наибольшей строке
            {
                while (str1.IndexOf(clone1) != -1) //Если есть, то прибавляю к этому символу следующий и ищу вхождение
                {

                    if (index + i == str2.Length) //проверяю, чтобы index не вышел за пределы длинны массива
                        break;
                    else
                    {
                        clone1 += str2[i + index];
                        ++index;
                    }
                }

                arrResulst[indexArr] = clone1.Substring(0, clone1.Length - 1); // записываю результат, отсекая последний элемент, так как он лишний и именно с ним на конце не нашлось ни одного вхождения
                ++indexArr;
                arrResulst.Add("");
                index = 1;
            }
        }
        switch (arrResulst.Count)
        {
            case 0:
                result = "Вхождений не обнаружено!"; break;
            case 1:
                result = arrResulst.First(); break;
            default:
                arrResulst.Sort((x, y) => x.Length.CompareTo(y.Length)); //Здесь используется делегат Comparison<T>, который принимает в себя анонимный метод,
                                                                         //если x>y return 1
                                                                         //если x<y return -1
                                                                         //если x=y return 0
                result = arrResulst.Last(); //получаю последний наибольшей длинны последовательность
                break;
        }
    }
